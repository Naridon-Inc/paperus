.DS_Store
package-lock.json
node_modules
dist
*.ai
out/
temp_restore/
old_repo/
backup_styles/
SERVER_SETUP.md
TEST_ACCOUNTS.md
lightsail-deployment.json
.env
.env.*
!.env.example
!.env.selfhost.example
dist-web/
*.cjs
yarn.lock

# Yjs persistence data (should not be in version control)
**/.notionless/history/

# Company Brain persistent vector index — local, machine-specific embeddings
# (rebuilds from the notes themselves). Same trust boundary as the notes, but
# large and not meant to be shared/committed. Note: .notionless/manifest.json
# IS tracked, so we ignore only the brain index, not the whole dir.
**/.notionless/brain-index.json

# Aura tooling snapshots (local dev tool, not part of the project)
.aura/

# Logs / editor scratch
*.log
.vite/

# First-party marketing-site analytics data (local append-only event store).
# Anonymous + aggregate, but machine-local and not meant to be committed.
backend/.analytics/

# Mobile native (Expo / React Native)
# node_modules + dist are already ignored above (match at any depth). These are
# the generated native projects (regenerated by `expo prebuild`) and caches —
# never commit them (ios/Pods alone is >1GB).
apps/mobile-native/ios/
apps/mobile-native/android/
**/.expo/

# Mobile web / PWA build output
dist-mobile/

# Generated landing-site mirror (produced by `pnpm run build:site` from landing/)
backend/public/

# Local AI-assistant tooling artifacts (not part of the project)
.gemini/
.gemini.intent
GEMINI.md
producthunt/
.mcp.json
.claude/
