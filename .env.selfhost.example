# Notionless self-host config. Copy to `.env`, edit, then:
#   docker compose -f docker-compose.selfhost.yml up -d
#
# The ONLY thing most people change is NL_DOMAIN (+ NL_TLS_EMAIL).

# ---------------------------------------------------------------------------
# Your public hostname. Point a DNS A record at this box, set it here, and Caddy
# fetches + auto-renews a Let's Encrypt HTTPS cert for it. No cert files, no
# certbot, nothing else to do.
#
#   NL_DOMAIN=docs.yourcompany.com
#
# Leave it as `:80` to run locally over plain HTTP (open http://localhost).
NL_DOMAIN=:80

# Email for the Let's Encrypt account (cert-expiry notices). Recommended once you
# set a real NL_DOMAIN. Ignored for the `:80` local case.
NL_TLS_EMAIL=

# ===========================================================================
# THE ONE SWITCH — pick how this instance runs:
#
#   NL_MODE=online   (default)  Your own full online Notion. The box stores every
#                               note's ENCRYPTED state and serves it 24/7, so your
#                               team gets a web app (usable from any browser,
#                               anywhere) with docs synced across web + desktop +
#                               mobile, plus always-on realtime collaboration. The
#                               box can never read your notes (ciphertext only).
#
#   NL_MODE=p2p                 Pure peer-to-peer. The box only brokers connections
#                               and stores NOTHING; notes sync directly between
#                               devices while ≥1 is online. (Same as just using the
#                               apps with the free public relay — but on your box.)
#
# This single value flips both the relay and the web app. Leave the advanced
# NL_PERSIST_DIR / NL_CLOUD_SYNC_URL knobs below blank unless you know you need
# them — NL_MODE drives the sane defaults.
# ===========================================================================
NL_MODE=online

# ---------------------------------------------------------------------------
# Optional knobs — sensible defaults, most people leave these blank.

# Comma-separated extra web origins allowed to call the relay API. The web app's
# own origin is always allowed, so you usually need nothing here.
NL_ALLOWED_ORIGINS=

# Advanced overrides for the always-on encrypted store. Normally you DON'T touch
# these — NL_MODE above already sets them (online → persist to /data + mirror to
# /yjs; p2p → both off). Set them only for non-standard layouts, e.g. pointing the
# web app at a DIFFERENT box (NL_CLOUD_SYNC_URL=wss://other-box.example.com/yjs).
NL_PERSIST_DIR=
NL_CLOUD_SYNC_URL=

# Where the in-app "Download the desktop app" buttons point. Defaults to the
# official GitHub release; set this if you ship your own fork's build.
NL_DOWNLOAD_URL=

# Optional accounts layer (hybrid identity). Set to 1 to put an email/password
# sign-in in front of this web instance, on top of the default zero-account
# identity. Leave blank for the pure zero-account experience. Notes stay E2EE
# either way — an account only gates access, it can never read your content.
# The FIRST account created becomes the admin. See docs/SELF_HOSTING.md.
NL_ACCOUNTS=
# Who may sign up: "open" (anyone, good for a trusted company instance) or
# "closed" (only the first/admin account self-serves; others are admin-added via
# an invite link or "Add user" in the in-app Members panel).
NL_ACCOUNTS_SIGNUP=open
# Set 1 to also reject UNauthenticated sync (members-only instance). Leave blank
# unless you want to hard-lock the relay to signed-in users.
NL_ACCOUNTS_STRICT=
# Deterministic ROOT admin (super-admin), seeded on first boot when no users
# exist yet. Set BOTH to guarantee a known admin the moment the instance comes up
# — instead of "whoever signs up first becomes admin" (a race on a public URL).
# Re-applying on later boots is a no-op once any account exists. Highly
# recommended whenever NL_ACCOUNTS_SIGNUP=closed and/or NL_ACCOUNTS_STRICT=1.
NL_ADMIN_EMAIL=
NL_ADMIN_PASSWORD=
# Fixed secret so login sessions survive a relay restart. `openssl rand -hex 32`.
NL_ACCOUNTS_SECRET=

# Token to read the landing-page analytics dashboard (/stats.html). Only matters
# if you also serve the marketing page from this box. `openssl rand -hex 24`.
NL_ANALYTICS_TOKEN=
