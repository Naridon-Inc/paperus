g.createEncoder();\n        encoding.writeVarUint(encoder, messageAwareness);\n        const update = awarenessProtocol.encodeAwarenessUpdate(awareness, changedClients);\n        encoding.writeVarUint8Array(encoder, update);\n        const buff = encoding.toUint8Array(encoder);\n        clients.forEach(client => {\n          if (client !== origin) send(client, buff);\n        });\n      });\n\n      const updates = await prisma.yjsUpdate.findMany({\n          where: { docId: docName },\n          orderBy: { id: 'asc' }\n      });\n      if (updates.length > 0) {\n        logger.debug('yjs', 'Loading updates from DB', { docName, count: updates.length });\n        Y.applyUpdate(doc, Y.mergeUpdates(updates.map(u => u.updateBlob)), 'db-load');\n        updateCount = updates.length;\n      } else {\n        // Fallback: Seed from Document table backup if it exists\n        const docRecord = await prisma.document.findUnique({ where: { id: docName } });\n        if (docRecord && docRecord.content && docRecord.content.trim().length > 0) {\n            console.log(`[Yjs] Seeding ${docName} from REST backup content`);\n            const yContent = doc.getText('content');\n            \n            if (docRecord.content.startsWith('{')) {\n                // Quill Delta JSON - we can't easily apply this to a raw Y.Text \n                // without the Quill binding, but we can try to apply it to a fresh Y.Doc \n                // and then apply that update.\n                try {\n                    const delta = JSON.parse(docRecord.content);\n                    // Just store the raw content for now if it's JSON, \n                    // the client will handle it during migration.\n                    yContent.insert(0, docRecord.content);\n                } catch (e) {\n                    console.error('[Yjs] Failed to parse Delta JSON:', e);\n                }\n            } else {\n                // Markdown or Plain Text\n                yContent.insert(0, docRecord.content);\n                // Save this as the first update\n                const initialUpdate = Y.encodeStateAsUpdate(doc);\n                await prisma.yjsUpdate.create({\n                    data: {\n                        docId: docName,\n                        clock: BigInt(Date.now()),\n                        updateBlob: Buffer.from(initialUpdate)\n                    }\n                }).catch(e => console.error('[Yjs] Failed to save initial seed update:', e));\n            }\n        }\n      }\n\n      return { doc, awareness, clients };\n  })",
